# === 接続先 LLM (OpenAI 互換 API) ===
# OpenAI 互換 API なら何でも使える: LM Studio / Ollama / vLLM /
# Gemini (OpenAI 互換層) / OpenAI / Together / DeepSeek 等。
# 切替は下の 3 行を変えて Streamlit を再起動するだけ。
#
# 例 1: LM Studio (ローカル / 学内サーバ)
#   LOCAL_BASE_URL=http://localhost:1234/v1
#   LOCAL_MODEL=google/gemma-4-26b-a4b
#   LOCAL_API_KEY=not-used
#
# 例 2: Gemini (OpenAI 互換層) に切替
#   LOCAL_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   LOCAL_MODEL=gemini-2.5-flash-lite
#   LOCAL_API_KEY=<Gemini の API キー>

LOCAL_BASE_URL=http://localhost:1234/v1
LOCAL_MODEL=google/gemma-4-26b-a4b
LOCAL_API_KEY=not-used
